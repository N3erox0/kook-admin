# 服务端环境变量模板（多公会架构 V3）
# 复制此文件为 .env 并填入实际值

APP_PORT=3000
APP_ENV=production
FRONTEND_URL=https://22bngm.online

# ===== MySQL 数据库 =====
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_DATABASE=kook_admin

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT 认证（请更换为随机字符串） =====
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_32CHARS
JWT_EXPIRES_IN=2h
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ===== 腾讯云 OCR / COS（全局配置） =====
TENCENT_SECRET_ID=YOUR_TENCENT_SECRET_ID
TENCENT_SECRET_KEY=YOUR_TENCENT_SECRET_KEY
COS_BUCKET=YOUR_COS_BUCKET_NAME
COS_REGION=ap-guangzhou
OCR_REGION=ap-guangzhou

# ===== KOOK 全局配置（Webhook 验证用） =====
# Bot Token 和 Guild/Channel ID 已迁移到数据库 guilds 表，由每个公会独立配置
# 以下为全局 Webhook 验证和 OAuth 配置
KOOK_VERIFY_TOKEN=YOUR_KOOK_VERIFY_TOKEN
KOOK_CLIENT_ID=YOUR_KOOK_CLIENT_ID
KOOK_CLIENT_SECRET=YOUR_KOOK_CLIENT_SECRET

# ===== KOOK 默认配置（单公会兼容模式） =====
# 如果只有一个公会，也可在此配置（优先级低于数据库）
KOOK_BOT_TOKEN=
KOOK_GUILD_ID=
KOOK_CHANNEL_ID=
